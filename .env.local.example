# Supabase project URL — get from supabase.com dashboard
NEXT_PUBLIC_SUPABASE_URL=
# Supabase anon key — safe for browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Google OAuth client ID — from Google Cloud Console → APIs & Services → Credentials
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
# Supabase service role key — Edge Functions ONLY, NEVER in client code
SUPABASE_SERVICE_ROLE_KEY=
# Resend API key — get from resend.com → API Keys
RESEND_API_KEY=
# Resend webhook signing secret — get from resend.com → Webhooks → signing secret
RESEND_WEBHOOK_SECRET=
# Resend verified sending address — update after verifying domain (default: onboarding@resend.dev)
FROM_EMAIL="Compliance Alerts <alerts@yourdomain.com>"

# Polar.sh — get from polar.sh dashboard
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
# Sentry DSN — get from sentry.io
SENTRY_DSN=
# App URL — ngrok tunnel URL for webhook testing, domain for production
NEXT_PUBLIC_APP_URL=http://localhost:3000